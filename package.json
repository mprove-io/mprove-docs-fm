{
  "name": "mprove-docs-fm",
  "version": "11.0.90-1",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "next-start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "check-links": "bun scripts/lint.ts",
    "lint": "biome check",
    "format": "biome format --write",
    "clean:node_modules": "rm -rf ./node_modules/* && rm -rf ./node_modules/.bin/*&& rm -rf ./node_modules/.cache/* && rm -rf ./node_modules/.pnpm/* && rm -rf ./node_modules/.tmp/* && rm -rf ./node_modules/.modules.yaml && rm -rf ./node_modules/.pnpm-workspace-state-v1.json"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "1.1.13",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "16.3.0",
    "fumadocs-mdx": "14.1.1",
    "fumadocs-ui": "16.3.0",
    "lucide-react": "^0.561.0",
    "next": "16.0.10",
    "next-validate-link": "1.6.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shiki": "3.20.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bun": "^1.3.5",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
